# Copy to .env and fill in your Supabase Postgres connection string.
# URL-encode special characters in the password (e.g. '@' -> '%40').
# For Vercel / IPv4 networks use the "Connection Pooling" string (port 6543).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Supabase Auth (anon key is public/safe). Dashboard -> Settings -> API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Zong 4G (Huawei) router — for the Devices tab. Server-side only.
# Only works when the app runs locally on the router's Wi-Fi (npm run dev);
# a Vercel deployment cannot reach 192.168.8.1.
ZONG_ROUTER_HOST=http://192.168.8.1
ZONG_ROUTER_USERNAME=admin
ZONG_ROUTER_PASSWORD=afnan@90
