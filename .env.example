# Copy to .env and fill in your Supabase Postgres connection string.
# URL-encode special characters in the password (e.g. '@' -> '%40').
# For Vercel / IPv4 networks use the "Connection Pooling" string (port 6543).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Supabase Auth (anon key is public/safe). Dashboard -> Settings -> API.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Zong 4G (Huawei) router — for the Devices tab. Server-side only.
# Only works when the code runs on the router's Wi-Fi (192.168.8.1 is LAN-only):
# either local `npm run dev`, or the home agent `npm run agent` (see below).
ZONG_ROUTER_HOST=http://192.168.8.1
ZONG_ROUTER_USERNAME=admin
ZONG_ROUTER_PASSWORD=afnan@90

# --- Devices on the DEPLOYED app: home router agent (Supabase Realtime relay) ---
# The deployed server can't reach 192.168.8.1, so `npm run agent` runs on a home
# machine (on the Zong Wi-Fi) and relays commands over a private Realtime channel.
# See ROUTER_AGENT.md for setup (incl. the required RLS policies).
#
# Frontend transport: 'http' (default, local dev) or 'realtime' (set on Vercel).
VITE_ROUTER_TRANSPORT=http
# Channel name shared by the app and the agent (must match on both).
VITE_ROUTER_CHANNEL=router-control
# Supabase account the agent signs in as — MUST be the Devices-allowed email.
ROUTER_AGENT_EMAIL=afnan.akram911@gmail.com
ROUTER_AGENT_PASSWORD=<supabase-account-password>
